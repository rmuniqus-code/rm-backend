# Copy to .env and fill in.
# Never commit .env.

# Supabase — the URL and anon key may match the frontend values,
# but SERVICE_ROLE_KEY must live only here (backend).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGIN=http://localhost:4000

# Server port.
PORT=5000

# Node env — set to "development" for the reset-db endpoint to be enabled.
NODE_ENV=development
